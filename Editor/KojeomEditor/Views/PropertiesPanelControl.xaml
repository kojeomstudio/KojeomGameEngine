<UserControl x:Class="KojeomEditor.Views.PropertiesPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ViewModels="clr-namespace:KojeomEditor.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="300">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="8,4">
            <TextBlock Text="Properties" FontWeight="Bold" FontSize="12"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <ContentControl Content="{Binding PropertiesViewModel.SelectedActor}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type ViewModels:ActorViewModel}">
                            <StackPanel>
                                <TextBlock Text="Transform" FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>
                                
                                <TextBlock Text="Position" Foreground="#999" FontSize="10" Margin="0,4,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,2,0">
                                        <TextBlock Text="X" Foreground="#F44" FontSize="9"/>
                                        <TextBox Text="{Binding PositionX, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="2,0">
                                        <TextBlock Text="Y" Foreground="#4F4" FontSize="9"/>
                                        <TextBox Text="{Binding PositionY, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="2,0,0,0">
                                        <TextBlock Text="Z" Foreground="#44F" FontSize="9"/>
                                        <TextBox Text="{Binding PositionZ, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Rotation" Foreground="#999" FontSize="10" Margin="0,12,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,2,0">
                                        <TextBlock Text="X" Foreground="#F44" FontSize="9"/>
                                        <TextBox Text="{Binding RotationX, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="2,0">
                                        <TextBlock Text="Y" Foreground="#4F4" FontSize="9"/>
                                        <TextBox Text="{Binding RotationY, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="2,0,0,0">
                                        <TextBlock Text="Z" Foreground="#44F" FontSize="9"/>
                                        <TextBox Text="{Binding RotationZ, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Scale" Foreground="#999" FontSize="10" Margin="0,12,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,2,0">
                                        <TextBlock Text="X" Foreground="#F44" FontSize="9"/>
                                        <TextBox Text="{Binding ScaleX, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="2,0">
                                        <TextBlock Text="Y" Foreground="#4F4" FontSize="9"/>
                                        <TextBox Text="{Binding ScaleY, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="2,0,0,0">
                                        <TextBlock Text="Z" Foreground="#44F" FontSize="9"/>
                                        <TextBox Text="{Binding ScaleZ, UpdateSourceTrigger=PropertyChanged}" Padding="2"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="General" FontWeight="Bold" FontSize="12" Margin="0,16,0,8"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Name: " VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Visible: " VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding IsVisible}" VerticalAlignment="Center"/>
                                </Grid>

                                <TextBlock Text="Components" FontWeight="Bold" FontSize="12" Margin="0,16,0,8"/>
                                <ItemsControl ItemsSource="{Binding Components}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander Header="{Binding Name}" Margin="0,2,0,2" Background="#3C3C3C">
                                                <ContentControl Content="{Binding}" Margin="4">
                                                    <ContentControl.Resources>
                                                        <DataTemplate DataType="{x:Type ViewModels:StaticMeshComponentViewModel}">
                                                            <StackPanel>
                                                                <TextBlock Text="Mesh Path:" Foreground="#999" FontSize="10"/>
                                                                <TextBox Text="{Binding MeshPath}" IsReadOnly="True" Margin="0,2,0,4"/>
                                                                <TextBlock Text="Material Path:" Foreground="#999" FontSize="10"/>
                                                                <TextBox Text="{Binding MaterialPath}" IsReadOnly="True" Margin="0,2,0,4"/>
                                                                <CheckBox Content="Cast Shadows" IsChecked="{Binding CastShadows}" Margin="0,2"/>
                                                                <CheckBox Content="Receive Shadows" IsChecked="{Binding ReceiveShadows}" Margin="0,2"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                        <DataTemplate DataType="{x:Type ViewModels:LightComponentViewModel}">
                                                            <StackPanel>
                                                                <Grid Margin="0,2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="Type: " VerticalAlignment="Center"/>
                                                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding LightType}" Margin="4,0,0,0">
                                                                        <ComboBoxItem Content="Directional"/>
                                                                        <ComboBoxItem Content="Point"/>
                                                                        <ComboBoxItem Content="Spot"/>
                                                                    </ComboBox>
                                                                </Grid>
                                                                <TextBlock Text="Intensity:" Foreground="#999" FontSize="10" Margin="0,4,0,2"/>
                                                                <Slider Value="{Binding Intensity}" Minimum="0" Maximum="10" SmallChange="0.1" LargeChange="1"/>
                                                                <TextBlock Text="Color (RGB):" Foreground="#999" FontSize="10" Margin="0,4,0,2"/>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBox Grid.Column="0" Text="{Binding ColorR, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,2,0"/>
                                                                    <TextBox Grid.Column="1" Text="{Binding ColorG, UpdateSourceTrigger=PropertyChanged}" Margin="2,0"/>
                                                                    <TextBox Grid.Column="2" Text="{Binding ColorB, UpdateSourceTrigger=PropertyChanged}" Margin="2,0,0,0"/>
                                                                </Grid>
                                                                <TextBlock Text="Range:" Foreground="#999" FontSize="10" Margin="0,4,0,2"/>
                                                                <Slider Value="{Binding Range}" Minimum="0" Maximum="100" SmallChange="1" LargeChange="10"/>
                                                                <CheckBox Content="Cast Shadows" IsChecked="{Binding CastShadows}" Margin="0,4"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                        <DataTemplate DataType="{x:Type ViewModels:CameraComponentViewModel}">
                                                            <StackPanel>
                                                                <TextBlock Text="Field of View:" Foreground="#999" FontSize="10" Margin="0,2,0,2"/>
                                                                <Slider Value="{Binding FieldOfView}" Minimum="10" Maximum="120" SmallChange="1" LargeChange="10"/>
                                                                <Grid Margin="0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="Near Plane: " VerticalAlignment="Center"/>
                                                                    <TextBox Grid.Column="1" Text="{Binding NearPlane}" Margin="4,0,0,0"/>
                                                                </Grid>
                                                                <Grid Margin="0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="Far Plane: " VerticalAlignment="Center"/>
                                                                    <TextBox Grid.Column="1" Text="{Binding FarPlane}" Margin="4,0,0,0"/>
                                                                </Grid>
                                                                <CheckBox Content="Perspective" IsChecked="{Binding IsPerspective}" Margin="0,4"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                        <DataTemplate DataType="{x:Type ViewModels:ComponentViewModel}">
                                                            <TextBlock Text="{Binding TypeDisplayName}" Foreground="#999"/>
                                                        </DataTemplate>
                                                    </ContentControl.Resources>
                                                </ContentControl>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
