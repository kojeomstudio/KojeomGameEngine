<Window x:Class="KojeomEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KojeomEditor"
        xmlns:views="clr-namespace:KojeomEditor.Views"
        mc:Ignorable="d"
        Title="Kojeom Engine Editor" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#2D2D30" Foreground="White">
            <MenuItem Header="_File">
                <MenuItem Header="_New Scene" Click="MenuItem_NewScene_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open Scene" Click="MenuItem_OpenScene_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save Scene" Click="MenuItem_SaveScene_Click" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuItem_Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Delete" InputGestureText="Delete"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Scene Hierarchy" IsCheckable="True" IsChecked="True"/>
                <MenuItem Header="Properties" IsCheckable="True" IsChecked="True"/>
                <MenuItem Header="Content Browser" IsCheckable="True" IsChecked="True"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="1" Background="#2D2D30">
            <ToolBar Band="0" BandIndex="0" Background="#2D2D30">
                <Button ToolTip="Select" Padding="5">
                    <TextBlock Text="Select" FontWeight="Bold"/>
                </Button>
                <Button ToolTip="Move" Padding="5">
                    <TextBlock Text="Move" FontWeight="Bold"/>
                </Button>
                <Button ToolTip="Rotate" Padding="5">
                    <TextBlock Text="Rotate" FontWeight="Bold"/>
                </Button>
                <Button ToolTip="Scale" Padding="5">
                    <TextBlock Text="Scale" FontWeight="Bold"/>
                </Button>
                <Separator/>
                <Button ToolTip="Play" Padding="5">
                    <TextBlock Text="▶" FontSize="14"/>
                </Button>
                <Button ToolTip="Pause" Padding="5">
                    <TextBlock Text="⏸" FontSize="14"/>
                </Button>
                <Button ToolTip="Stop" Padding="5">
                    <TextBlock Text="⏹" FontSize="14"/>
                </Button>
            </ToolBar>
        </ToolBarTray>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Scene Hierarchy Panel -->
            <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
                <views:SceneHierarchyControl/>
            </Border>

            <!-- Viewport -->
            <Border Grid.Column="1" Background="#1E1E1E">
                <views:ViewportControl/>
            </Border>

            <!-- Properties Panel -->
            <Border Grid.Column="2" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                <views:PropertiesPanelControl/>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="Ready"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="FPS: 60"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
