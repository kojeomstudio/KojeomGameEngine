<Window x:Class="KojeomEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KojeomEditor"
        xmlns:views="clr-namespace:KojeomEditor.Views"
        mc:Ignorable="d"
        Title="Kojeom Engine Editor" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#2D2D30" Foreground="White">
            <MenuItem Header="_File">
                <MenuItem Header="_New Scene" Click="MenuItem_NewScene_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open Scene" Click="MenuItem_OpenScene_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save Scene" Click="MenuItem_SaveScene_Click" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuItem_Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGestureText="Ctrl+Z" Click="MenuItem_Undo_Click"/>
                <MenuItem Header="_Redo" InputGestureText="Ctrl+Y" Click="MenuItem_Redo_Click"/>
                <Separator/>
                <MenuItem Header="_Delete" InputGestureText="Delete" Click="MenuItem_Delete_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Scene Hierarchy" IsCheckable="True" IsChecked="True"/>
                <MenuItem Header="Properties" IsCheckable="True" IsChecked="True"/>
                <MenuItem Header="Content Browser" IsCheckable="True" IsChecked="True"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About"/>
            </MenuItem>
        </Menu>

        <ToolBarTray Grid.Row="1" Background="#2D2D30">
            <ToolBar Band="0" BandIndex="0" Background="#2D2D30">
                <Button ToolTip="Select (Q)" Padding="5" Click="Toolbar_Select_Click">
                    <TextBlock Text="Select" FontWeight="Bold"/>
                </Button>
                <Button ToolTip="Move (W)" Padding="5" Click="Toolbar_Move_Click">
                    <TextBlock Text="Move" FontWeight="Bold"/>
                </Button>
                <Button ToolTip="Rotate (E)" Padding="5" Click="Toolbar_Rotate_Click">
                    <TextBlock Text="Rotate" FontWeight="Bold"/>
                </Button>
                <Button ToolTip="Scale (R)" Padding="5" Click="Toolbar_Scale_Click">
                    <TextBlock Text="Scale" FontWeight="Bold"/>
                </Button>
                <Separator/>
                <Button ToolTip="Play" Padding="5" Click="Toolbar_Play_Click">
                    <TextBlock Text="&#x25B6;" FontSize="14"/>
                </Button>
                <Button ToolTip="Pause" Padding="5" Click="Toolbar_Pause_Click">
                    <TextBlock Text="&#x23F8;" FontSize="14"/>
                </Button>
                <Button ToolTip="Stop" Padding="5" Click="Toolbar_Stop_Click">
                    <TextBlock Text="&#x23F9;" FontSize="14"/>
                </Button>
            </ToolBar>
        </ToolBarTray>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
                    <views:SceneHierarchyControl/>
                </Border>

                <Border Grid.Column="1" Background="#1E1E1E">
                    <views:ViewportControl x:Name="Viewport"/>
                </Border>

                <Border Grid.Column="2" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <views:PropertiesPanelControl Grid.Row="0"/>
                        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#3F3F46"/>
                        <views:MaterialEditorControl Grid.Row="2" Height="400"/>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#3F3F46"/>

            <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
                <views:ContentBrowserControl/>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBlock x:Name="StatusReady" Text="Ready"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusDrawCalls" Text="Draw Calls: 0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusFPS" Text="FPS: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
